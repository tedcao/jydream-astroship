---
type Cell = { kind: "yes" | "no" | "partial" } | { kind: "text"; text: string };

const rows: [string, Cell, Cell, Cell, Cell, Cell][] = [
  ["Overseas expansion strategy", { kind: "yes" }, { kind: "yes" }, { kind: "no" }, { kind: "partial" }, { kind: "no" }],
  ["Market setup + compliance coordination", { kind: "yes" }, { kind: "partial" }, { kind: "no" }, { kind: "no" }, { kind: "partial" }],
  ["Channel launch services", { kind: "yes" }, { kind: "no" }, { kind: "yes" }, { kind: "partial" }, { kind: "partial" }],
  ["JYDream Dashboard visibility", { kind: "yes" }, { kind: "no" }, { kind: "no" }, { kind: "no" }, { kind: "no" }],
  ["Local customer and partner experience", { kind: "yes" }, { kind: "partial" }, { kind: "partial" }, { kind: "partial" }, { kind: "partial" }],
  ["US + Canada operating context", { kind: "yes" }, { kind: "partial" }, { kind: "partial" }, { kind: "yes" }, { kind: "partial" }],
  ["Asia-to-NA communication bridge", { kind: "yes" }, { kind: "partial" }, { kind: "no" }, { kind: "partial" }, { kind: "partial" }],
  ["Clean handoff path", { kind: "yes" }, { kind: "no" }, { kind: "no" }, { kind: "partial" }, { kind: "yes" }],
  ["How it starts", { kind: "text", text: "2 months free" }, { kind: "text", text: "Paid diagnostic" }, { kind: "text", text: "Paid retainer" }, { kind: "text", text: "Paid monthly" }, { kind: "text", text: "Hiring cost" }],
];
const heads = ["Capability", "JYDream", "Big-4 consulting", "Amazon agency", "Fractional GM", "Hiring a team"];
---

<section class="ld-section">
  <div class="ld-container">
    <div class="section-head">
      <span class="eyebrow">The alternatives</span>
      <h2 class="section-title">
        A consulting partner for expansion, <em>not another SaaS subscription</em>.
      </h2>
      <p class="section-sub">
        Companies entering North America usually choose between consultants,
        agencies, a fractional GM, or hiring locally. JYDream combines service
        execution, Dashboard visibility, and local experience.
      </p>
    </div>
    <div class="cmp-wrap">
      <table class="cmp-table">
        <thead>
          <tr>
            {heads.map((h, i) => (
              <th class:list={[i === 1 && "hl"]}>{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              {row.map((cell, j) => (
                <td class:list={[j === 1 && "hl"]}>
                  {typeof cell === "string" ? (
                    <span>{cell}</span>
                  ) : cell.kind === "yes" ? (
                    <span class="cmp-yes">✓</span>
                  ) : cell.kind === "no" ? (
                    <span class="cmp-no">—</span>
                  ) : cell.kind === "partial" ? (
                    <span class="cmp-partial">Partial</span>
                  ) : (
                    <span>{cell.text}</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="cmp-cap">
      The first two months are free, with no commitment to continue.
    </p>
  </div>
</section>
