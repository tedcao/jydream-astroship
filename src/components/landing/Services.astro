---
import Icons from "./Icons.astro";

type Illus =
  | "sync"
  | "ledger"
  | "ai"
  | "social"
  | "timeline"
  | "acc"
  | "crm";

interface Service {
  key: string;
  tag: "Toronto" | "China" | "Partners" | "Dashboard";
  vertical: "both" | "commerce" | "service";
  wide?: boolean;
  coral?: boolean;
  iconName:
    | "box"
    | "wrench"
    | "coin"
    | "sparkle"
    | "share"
    | "bell"
    | "users";
  title: string;
  bene: string;
  bullets: string[];
  illus: Illus;
}

const services: Service[] = [
  {
    key: "website-sales",
    tag: "Toronto",
    vertical: "both",
    wide: true,
    coral: true,
    iconName: "sparkle",
    title: "Your website gets visitors, but the follow-up is messy.",
    bene:
      "For Toronto service businesses, we build the practical digital layer around the website: inquiry forms, booking paths, sales follow-up, customer records, and reporting.",
    bullets: [
      "Website and landing pages that explain the service clearly",
      "Lead capture, booking requests, and sales follow-up workflow",
      "Simple reporting so owners know where inquiries are coming from",
    ],
    illus: "sync",
  },
  {
    key: "customer-service",
    tag: "Toronto",
    vertical: "both",
    iconName: "bell",
    title: "Customers ask questions, but support lives in too many places.",
    bene:
      "We organize customer service, sales notes, and reminders so a local business can respond faster without losing context.",
    bullets: [
      "Email, form, SMS, and service requests in one workflow",
      "Accessory or replacement reminders for recurring revenue",
      "Owner-friendly handoff notes for every customer interaction",
    ],
    illus: "timeline",
  },
  {
    key: "china-export",
    tag: "China",
    vertical: "commerce",
    coral: true,
    iconName: "box",
    title: "China factories need a credible overseas-facing presence.",
    bene:
      "We help China-based factories and brands prepare for English-speaking buyers with clearer websites, product pages, sales materials, and inquiry flows.",
    bullets: [
      "English website and product presentation for overseas buyers",
      "B2B inquiry forms, catalog structure, and sales material",
      "North America market-entry notes before spending heavily",
    ],
    illus: "social",
  },
  {
    key: "tax-capital",
    tag: "Partners",
    vertical: "commerce",
    iconName: "coin",
    title: "Expansion questions often become tax, accounting, or financing questions.",
    bene:
      "We coordinate with global accountant and tax partners and help founders understand the practical questions behind US/Canada setup, Nasdaq listing paths, and capital-market conversations.",
    bullets: [
      "Global accountant and tax partner coordination",
      "US/Canada setup, sales tax, GST/HST, and compliance questions",
      "Capital-market readiness context for licensed advisors",
    ],
    illus: "ledger",
  },
];
---

<section class="ld-section" id="services" data-section="services">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">What we do</span>
        <h2 class="section-title">
          We fix the operational gaps that block growth.
        </h2>
        <p class="section-sub">
          Most clients do not need another abstract strategy deck. They need a
          clearer website, faster follow-up, organized customer service,
          reliable reminders, and the right partners for tax, accounting, and
          overseas expansion decisions.
        </p>
      </div>
    </div>
    <div class="features-grid">
      {services.map((f) => (
        <article
          class:list={["feat", f.wide && "feat-wide"]}
          data-vertical={f.vertical}
        >
          <span class={`feat-tag ${f.tag.toLowerCase()}`}>{f.tag}</span>
          <div class:list={["feat-icon", f.coral && "coral"]}>
            <Icons name={f.iconName} />
          </div>
          <h3 class="feat-title">{f.title}</h3>
          <p class="feat-bene">{f.bene}</p>
          <ul class="feat-list">
            {f.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
          <div class="feat-illus">
            {f.illus === "sync" && (
              <div class="sync-illus">
                <div class="sync-node">
                  <div class="sync-node-head">
                    <span class="sync-node-dot" style="background: #95BF47;"></span>
                    Website inquiry
                  </div>
                  <div class="sync-node-body">New customer · service request</div>
                </div>
                <div class="sync-line"></div>
                <div class="sync-node">
                  <div class="sync-node-head">
                    <span class="sync-node-dot" style="background: #FF9900;"></span>
                    Sales follow-up
                  </div>
                  <div class="sync-node-body">Owner notified · next step logged</div>
                </div>
              </div>
            )}
            {f.illus === "ledger" && (
              <div class="ledger-illus">
                <div class="ledger-row">
                  <span class="ccy">TAX</span>
                  <span style="font-size: 11px; font-weight: 600;">Accountant questions</span>
                  <span class="ledger-method">Ready</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">CA</span>
                  <span style="font-size: 11px; font-weight: 600;">GST/HST context</span>
                  <span class="ledger-method">Review</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">US</span>
                  <span style="font-size: 11px; font-weight: 600;">Sales tax questions</span>
                  <span class="ledger-method">Review</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">CM</span>
                  <span style="font-size: 11px; font-weight: 600;">Nasdaq / financing path</span>
                  <span class="ledger-method">Context</span>
                </div>
              </div>
            )}
            {f.illus === "ai" && (
              <div class="ai-illus">
                <div class="ai-prompt">
                  › "Filtered water, premium, launching in US"<span class="ai-caret"></span>
                </div>
                <div class="ai-output">
                  <b>Positioning:</b> Premium countertop filtration for condo &amp; rental markets. Entry SKU $129, target Nordstrom &amp; West Elm…
                </div>
                <div class="ai-models">
                  <span class="ai-model active">US market</span>
                  <span class="ai-model">CA market</span>
                  <span class="ai-model">Category fit</span>
                </div>
              </div>
            )}
            {f.illus === "social" && (
              <div class="social-illus">
                <div class="social-post">
                  <span class="social-post-head">English site</span>
                  <span>Factory story, product categories, and inquiry path rewritten for overseas buyers.</span>
                </div>
                <div class="social-post">
                  <span class="social-post-head">Catalog</span>
                  <span>Product specs, customization notes, and MOQ questions organized for B2B sales.</span>
                </div>
                <div class="social-post">
                  <span class="social-post-head">Inquiry</span>
                  <span>Buyer questions routed to the right contact with useful sales context.</span>
                </div>
              </div>
            )}
            {f.illus === "timeline" && (
              <div class="tl-illus">
                <div class="tl-row">
                  <span class="tl-dot"></span>
                  <span class="tl-meta">09:04 ET</span>
                  <span class="tl-text">Service question · North York</span>
                  <span class="tl-ch">SMS</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot" style="background: #22C55E;"></span>
                  <span class="tl-meta">11:22 ET</span>
                  <span class="tl-text">Accessory reminder · Toronto</span>
                  <span class="tl-ch">Email</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot" style="background: #6366F1;"></span>
                  <span class="tl-meta">14:08 ET</span>
                  <span class="tl-text">Sales follow-up · Markham</span>
                  <span class="tl-ch">Chat</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot empty"></span>
                  <span class="tl-meta">queued</span>
                  <span class="tl-text">Owner review needed</span>
                  <span class="tl-ch">Handoff</span>
                </div>
              </div>
            )}
            {f.illus === "acc" && (
              <div class="acc-illus">
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="droplet" /></div>
                  <div class="acc-meta">
                    <div class="acc-name">Ceramic filter · NA 3PL</div>
                    <div class="acc-sub">Every 6 months · Lucía S.</div>
                  </div>
                  <span class="acc-due red">Due today</span>
                </div>
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="wrench" size={14} /></div>
                  <div class="acc-meta">
                    <div class="acc-name">Heater element · NA 3PL</div>
                    <div class="acc-sub">Every 12 months · Jin M.</div>
                  </div>
                  <span class="acc-due">+3 days</span>
                </div>
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="droplet" /></div>
                  <div class="acc-meta">
                    <div class="acc-name">RO membrane · NA 3PL</div>
                    <div class="acc-sub">Every 24 months · Priya K.</div>
                  </div>
                  <span class="acc-due">+18d</span>
                </div>
              </div>
            )}
            {f.illus === "crm" && (
              <div class="crm-illus">
                <div class="crm-head">
                  <div class="crm-ava">WD</div>
                  <div class="crm-info">
                    <div class="crm-name">WaterDoctor customer · Toronto, ON</div>
                    <div class="crm-email">service workflow · reminder due</div>
                  </div>
                </div>
                <div class="crm-channels">
                  <span class="crm-ch email">Email</span>
                  <span class="crm-ch sms">SMS</span>
                  <span class="crm-ch chat">Live chat</span>
                  <span class="crm-ch shopify">Website lead</span>
                  <span class="crm-ch amzn">Reminder</span>
                </div>
                <div class="crm-log">
                  Apr 18 · inquiry received · service booked<br />
                  Apr 14 · filter reminder sent<br />
                  Mar 02 · customer note updated
                </div>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
