---
import Icons from "./Icons.astro";

type Illus =
  | "sync"
  | "ledger"
  | "ai"
  | "social"
  | "timeline"
  | "acc"
  | "crm";

interface Service {
  key: string;
  tag: "Services" | "Dashboard" | "Local";
  vertical: "both" | "commerce" | "service";
  wide?: boolean;
  coral?: boolean;
  iconName:
    | "box"
    | "wrench"
    | "coin"
    | "sparkle"
    | "share"
    | "bell"
    | "users";
  title: string;
  bene: string;
  bullets: string[];
  illus: Illus;
}

const services: Service[] = [
  {
    key: "strategy",
    tag: "Services",
    vertical: "both",
    wide: true,
    coral: true,
    iconName: "sparkle",
    title: "Enterprise overseas expansion strategy for US + Canada.",
    bene:
      "We turn a broad overseas ambition into a practical market-entry plan: buyer language, category fit, channel sequence, risk list, and a 12-month roadmap your leadership can make decisions from.",
    bullets: [
      "Category and competitor benchmark for US + Canada",
      "Positioning, pricing, and channel-entry recommendation",
      "Brand-story and naming adaptation for local buyers",
      "12-month roadmap with ownership, budget, and decision gates",
    ],
    illus: "ai",
  },
  {
    key: "entity",
    tag: "Services",
    vertical: "both",
    iconName: "coin",
    title: "Market setup, compliance, and launch operations.",
    bene:
      "We coordinate the practical setup work that slows overseas expansion down: entity decisions, tax registration, product compliance, import paths, channel accounts, and launch checklists.",
    bullets: [
      "US + CA entity, tax, and registered-agent coordination",
      "Product compliance checklist and partner referrals",
      "Import broker, HS-code, and 3PL launch path",
      "Amazon, Shopify, B2B, or retail account readiness",
    ],
    illus: "ledger",
  },
  {
    key: "amazon",
    tag: "Services",
    vertical: "commerce",
    coral: true,
    iconName: "box",
    title: "Channel launch services across Amazon, Shopify, and B2B.",
    bene:
      "We help your first overseas channels go live with local buyer copy, listing structure, fulfillment decisions, reporting cadence, and the operators needed to keep the work moving.",
    bullets: [
      "Amazon and Shopify launch planning for US + Canada",
      "Listing, storefront, and offer structure in local language",
      "Fulfillment and return-flow setup with local partners",
      "Weekly operating review during the free pilot",
    ],
    illus: "sync",
  },
  {
    key: "content",
    tag: "Local",
    vertical: "commerce",
    iconName: "share",
    title: "Local messaging and customer acquisition experience.",
    bene:
      "Overseas expansion often fails in translation. We help adapt product stories, sales materials, creator briefs, and community language to how North American buyers actually evaluate products.",
    bullets: [
      "Product descriptions and sales materials in local voice",
      "Creator and partner outreach briefs for US + CA audiences",
      "Community and review strategy for technical categories",
      "Monthly learning notes from customer and channel feedback",
    ],
    illus: "social",
  },
  {
    key: "cs",
    tag: "Local",
    vertical: "both",
    wide: true,
    iconName: "bell",
    title: "Local customer service, partner coordination, and aftersales.",
    bene:
      "Your customers, channel partners, and installers need answers in their own timezone. We help build the local operating layer so your overseas business does not feel overseas to the buyer.",
    bullets: [
      "Customer service coverage across Pacific and Eastern time zones",
      "Warranty, returns, and escalation workflow design",
      "Local 3PL, service partner, and installer coordination",
      "Monthly issue summary with root-cause recommendations",
    ],
    illus: "timeline",
  },
  {
    key: "accessory",
    tag: "Local",
    vertical: "service",
    iconName: "wrench",
    title: "Local playbooks for serviced products and recurring parts.",
    bene:
      "For products that need service, parts, or replenishment, we help design the local operating playbook before small issues become brand-damaging overseas support problems.",
    bullets: [
      "Replacement and replenishment cadence planning",
      "Local service and warranty workflows",
      "Parts inventory logic with North American 3PL partners",
      "Customer cohort and repeat-order review",
    ],
    illus: "acc",
  },
  {
    key: "platform",
    tag: "Dashboard",
    vertical: "both",
    iconName: "users",
    title: "JYDream Dashboard — the service layer you can see.",
    bene:
      "The Dashboard is not a SaaS product we sell. It is the shared workspace for your engagement: tasks, channels, customer notes, blockers, decisions, and weekly reporting in one place.",
    bullets: [
      "Client-visible task board and weekly executive brief",
      "Channel, customer, and service notes connected to decisions",
      "Read-only access for leadership, finance, and operators",
      "Clean handover path if you later build your own local team",
    ],
    illus: "crm",
  },
];
---

<section class="ld-section" id="services" data-section="services">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">What we do</span>
        <h2 class="section-title">
          Services, Dashboard, and <em>local experience</em>.
        </h2>
        <p class="section-sub">
          JYDream is a consulting service for enterprise overseas expansion.
          We combine hands-on services, our JYDream Dashboard, and local
          North American experience so your team can enter the market with less
          guesswork.
        </p>
      </div>
      <div class="v-toggle" data-role="v-toggle">
        <button type="button" data-vertical="all" class="active">All</button>
        <button type="button" data-vertical="commerce">
          <span class="dot dot-c" style="margin-right: 6px;"></span>Product
        </button>
        <button type="button" data-vertical="service">
          <span class="dot dot-s" style="margin-right: 6px;"></span>Serviced
        </button>
      </div>
    </div>
    <div class="features-grid">
      {services.map((f) => (
        <article
          class:list={["feat", f.wide && "feat-wide"]}
          data-vertical={f.vertical}
        >
          <span class={`feat-tag ${f.tag.toLowerCase()}`}>{f.tag}</span>
          <div class:list={["feat-icon", f.coral && "coral"]}>
            <Icons name={f.iconName} />
          </div>
          <h3 class="feat-title">{f.title}</h3>
          <p class="feat-bene">{f.bene}</p>
          <ul class="feat-list">
            {f.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
          <div class="feat-illus">
            {f.illus === "sync" && (
              <div class="sync-illus">
                <div class="sync-node">
                  <div class="sync-node-head">
                    <span class="sync-node-dot" style="background: #95BF47;"></span>
                    Shopify · CA
                  </div>
                  <div class="sync-node-body">1,284 SKUs · 12m ago</div>
                </div>
                <div class="sync-line"></div>
                <div class="sync-node">
                  <div class="sync-node-head">
                    <span class="sync-node-dot" style="background: #FF9900;"></span>
                    Amazon · US
                  </div>
                  <div class="sync-node-body">1,284 SKUs · synced</div>
                </div>
              </div>
            )}
            {f.illus === "ledger" && (
              <div class="ledger-illus">
                <div class="ledger-row">
                  <span class="ccy">US</span>
                  <span style="font-size: 11px; font-weight: 600;">Delaware C-Corp</span>
                  <span class="ledger-method">Filed</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">CA</span>
                  <span style="font-size: 11px; font-weight: 600;">Ontario Inc.</span>
                  <span class="ledger-method">Filed</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">US</span>
                  <span style="font-size: 11px; font-weight: 600;">Sales tax · 14 states</span>
                  <span class="ledger-method">Active</span>
                </div>
                <div class="ledger-row">
                  <span class="ccy">CA</span>
                  <span style="font-size: 11px; font-weight: 600;">GST/HST</span>
                  <span class="ledger-method">Active</span>
                </div>
              </div>
            )}
            {f.illus === "ai" && (
              <div class="ai-illus">
                <div class="ai-prompt">
                  › "Filtered water, premium, launching in US"<span class="ai-caret"></span>
                </div>
                <div class="ai-output">
                  <b>Positioning:</b> Premium countertop filtration for condo &amp; rental markets. Entry SKU $129, target Nordstrom &amp; West Elm…
                </div>
                <div class="ai-models">
                  <span class="ai-model active">US market</span>
                  <span class="ai-model">CA market</span>
                  <span class="ai-model">Category fit</span>
                </div>
              </div>
            )}
            {f.illus === "social" && (
              <div class="social-illus">
                <div class="social-post">
                  <span class="social-post-head">TikTok Shop</span>
                  <span>Creator brief · 6 drafts shipped this week to NA creators tier 2-3.</span>
                </div>
                <div class="social-post">
                  <span class="social-post-head">Amazon A+</span>
                  <span>Module 4 rewritten in NA voice. CVR up 2.1pp since rollout.</span>
                </div>
                <div class="social-post">
                  <span class="social-post-head">Reddit</span>
                  <span>r/Frugal seeding approved — 3 earnest reviews drafted by our editors.</span>
                </div>
              </div>
            )}
            {f.illus === "timeline" && (
              <div class="tl-illus">
                <div class="tl-row">
                  <span class="tl-dot"></span>
                  <span class="tl-meta">09:04 PT</span>
                  <span class="tl-text">Install question · Seattle</span>
                  <span class="tl-ch">SMS</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot" style="background: #22C55E;"></span>
                  <span class="tl-meta">11:22 ET</span>
                  <span class="tl-text">Warranty claim · Montréal</span>
                  <span class="tl-ch">FR · Email</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot" style="background: #6366F1;"></span>
                  <span class="tl-meta">14:08 CT</span>
                  <span class="tl-text">Replacement order · Austin</span>
                  <span class="tl-ch">Chat</span>
                </div>
                <div class="tl-row">
                  <span class="tl-dot empty"></span>
                  <span class="tl-meta">queued</span>
                  <span class="tl-text">Escalated to engineering</span>
                  <span class="tl-ch">Handoff</span>
                </div>
              </div>
            )}
            {f.illus === "acc" && (
              <div class="acc-illus">
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="droplet" /></div>
                  <div class="acc-meta">
                    <div class="acc-name">Ceramic filter · NA 3PL</div>
                    <div class="acc-sub">Every 6 months · Lucía S.</div>
                  </div>
                  <span class="acc-due red">Due today</span>
                </div>
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="wrench" size={14} /></div>
                  <div class="acc-meta">
                    <div class="acc-name">Heater element · NA 3PL</div>
                    <div class="acc-sub">Every 12 months · Jin M.</div>
                  </div>
                  <span class="acc-due">+3 days</span>
                </div>
                <div class="acc-row">
                  <div class="acc-ico"><Icons name="droplet" /></div>
                  <div class="acc-meta">
                    <div class="acc-name">RO membrane · NA 3PL</div>
                    <div class="acc-sub">Every 24 months · Priya K.</div>
                  </div>
                  <span class="acc-due">+18d</span>
                </div>
              </div>
            )}
            {f.illus === "crm" && (
              <div class="crm-illus">
                <div class="crm-head">
                  <div class="crm-ava">MA</div>
                  <div class="crm-info">
                    <div class="crm-name">Maya Anand · Toronto, ON</div>
                    <div class="crm-email">maya@altura.co</div>
                  </div>
                </div>
                <div class="crm-channels">
                  <span class="crm-ch email">Email</span>
                  <span class="crm-ch sms">SMS</span>
                  <span class="crm-ch chat">Live chat</span>
                  <span class="crm-ch shopify">Shopify CA</span>
                  <span class="crm-ch amzn">Amazon US</span>
                </div>
                <div class="crm-log">
                  Apr 18 · order #4821 · $218.00 CAD<br />
                  Apr 14 · replacement confirmed · shipped<br />
                  Mar 02 · order #4612 · $98.00 USD
                </div>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
