---
import Icons from "./Icons.astro";
---

<section class="ld-section-tight" id="engagement" style="background: var(--bg-sunken);">
  <div class="ld-container">
    <div class="free-band">
      <div>
        <span class="eyebrow">Free pilot</span>
        <h2>2 months free. One workflow. No commitment.</h2>
      </div>
      <p>
        We pick one practical problem and build the first version with you:
        lead follow-up, customer service, reminders, China export readiness, or
        partner coordination.
      </p>
      <a class="btn btn-primary btn-lg" href="/contact">
        Start free <Icons name="arrow" />
      </a>
      </div>
  </div>
</section>
