---
import Icons from "./Icons.astro";
---

<nav class="ld-nav" id="ld-nav">
  <div class="ld-container nav-inner">
    <a class="logo" href="#top">
      <span class="logo-mark"><span>J</span></span>
      JYDream
    </a>
    <div class="nav-links">
      <a class="nav-link" href="#services">Services</a>
      <a class="nav-link" href="#client-work">Client work</a>
      <a class="nav-link" href="#articles">Articles</a>
      <a class="nav-link" href="#faq">FAQ</a>
      <a class="nav-link" href="/blog">Blog</a>
    </div>
    <div class="nav-right">
      <a class="btn btn-primary btn-sm" href="#cta">
        Start free
        <Icons name="arrow" />
      </a>
    </div>
  </div>
  <div class="nav-progress" id="ld-nav-progress"></div>
</nav>

<script>
  const nav = document.getElementById("ld-nav");
  const progress = document.getElementById("ld-nav-progress");
  const onScroll = () => {
    const s = window.scrollY;
    nav?.classList.toggle("scrolled", s > 4);
    const h = document.documentElement;
    const max = h.scrollHeight - h.clientHeight;
    const pct = max > 0 ? (s / max) * 100 : 0;
    if (progress) progress.style.width = pct + "%";
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
