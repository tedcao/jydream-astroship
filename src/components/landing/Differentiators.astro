---
const items: [string, string, string][] = [
  ["01", "Consulting first, tools second.", "The client is buying judgment, execution, and overseas expansion help. The Dashboard supports the work; it is not the thing we are trying to sell."],
  ["02", "Services that move from advice to execution.", "We can help with market-entry strategy, accountant and tax partner coordination, compliance planning, channel launch, customer service design, and operating reviews instead of stopping at a slide deck."],
  ["03", "Local and capital-market context.", "We understand the buyer language, partner expectations, support standards, and channel habits in North America, and we can help founders understand how Nasdaq listing paths and US capital markets are usually discussed with professional advisors."],
  ["04", "A clear start: 2 months free, no commitment.", "You see real work before making a paid decision. If the pilot is useful, we scope the next phase together; if not, you can walk away cleanly."],
];
---

<section class="ld-section">
  <div class="ld-container">
    <div class="section-head">
      <span class="eyebrow">Why JYDream</span>
      <h2 class="section-title">
        Built for companies that are serious about <em>going overseas</em>.
      </h2>
    </div>
    <div class="diff-grid">
      {items.map(([n, title, body]) => (
        <div class="diff-cell">
          <span class="diff-num">REASON {n}</span>
          <h3 class="diff-title">{title}</h3>
          <p class="diff-body">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
