---
import Icons from "./Icons.astro";

const faqs: [string, string][] = [
  ["Are you a SaaS product?", "No. JYDream is a consulting services firm for overseas expansion. The JYDream Dashboard is part of how we deliver and show the work; we do not sell it as a standalone subscription."],
  ["Who are your typical clients?", "Asian companies, brands, and corporates that want to enter or scale in the US & Canada without guessing their way through local channels, compliance, customer service, and partner setup."],
  ["What is included in the solution?", "Three pieces: consulting services, the JYDream Dashboard, and local experience. Services cover strategy and execution; the Dashboard keeps the work visible; local experience helps adapt decisions to the US and Canadian market."],
  ["What does it cost to start?", "The first two months are free. There is no commitment during that period. After the pilot, we scope a paid services engagement only if you want to continue."],
  ["Do you work with companies already present in North America?", "Yes. Many clients already have one channel live, usually Amazon or a basic website, and need help turning that into a more serious overseas expansion plan."],
  ["Where are you based?", "We work across Toronto, Shenzhen, and Seattle, with North American partners for fulfillment, customer service, compliance, and local execution."],
  ["What verticals do you know best?", "Water / air filtration, small home appliances, premium consumer electronics, specialty food & beverage, and B2B industrial accessories. We take on adjacent categories case by case."],
  ["Will I need to hire anyone in North America?", "Not to begin. The free pilot is designed to show what can be handled with JYDream and what might eventually belong inside your own local team."],
  ["Can I migrate off JYDream later?", "Yes. We build for a handoff from day one: accounts, working notes, exports, and runbooks should remain understandable to your team."],
  ["How quickly can you start?", "A first consultation can usually happen quickly after NDA. The free two-month pilot starts once we agree on a focused scope and the information we need from your team."],
  ["Do you sign NDAs?", "Yes, mutual NDA before any discovery call. We routinely handle confidential financials, supplier relationships, and IP roadmaps."],
];
---

<section class="ld-section" id="faq">
  <div class="ld-container">
    <div class="section-head" style="text-align: center; margin: 0 auto 56px;">
      <span class="eyebrow" style="justify-content: center;">FAQ</span>
      <h2 class="section-title">Questions, <em>answered plainly</em>.</h2>
    </div>
    <div class="faq-wrap" data-role="faq-wrap">
      {faqs.map(([q, a], i) => (
        <div class:list={["faq-item", i === 0 && "open"]}>
          <button class="faq-q" type="button">
            <span>{q}</span>
            <span class="faq-q-icon"><Icons name="plus" /></span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">{a}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDivElement>(".faq-item").forEach((item) => {
    const q = item.querySelector<HTMLButtonElement>(".faq-q");
    q?.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      item.parentElement
        ?.querySelectorAll(".faq-item")
        .forEach((el) => el.classList.remove("open"));
      if (!isOpen) item.classList.add("open");
    });
  });
</script>
