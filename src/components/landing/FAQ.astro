---
import Icons from "./Icons.astro";

const faqs: [string, string][] = [
  ["What problem does JYDream solve?", "We help owners turn scattered website leads, customer messages, sales follow-ups, service notes, and reminders into a clearer operating workflow. For China clients, we also help prepare a more credible North America-facing presence."],
  ["Who do you mainly serve?", "We mainly serve Toronto local businesses and China-based companies preparing for overseas markets. Typical work includes websites, customer service workflows, sales support, accessory reminders, English product presentation, and North America expansion planning."],
  ["Are you a SaaS product?", "No. JYDream is a consulting and implementation service. The JYDream Dashboard is the shared working layer we use with clients; it is not sold as a standalone SaaS subscription."],
  ["Can you help with tax, accounting, or capital-market questions?", "Yes. We can coordinate with global accountant and tax partners and help clients understand the practical questions around US/Canada setup, tax readiness, Nasdaq listing paths, and capital-market conversations. Formal tax, legal, audit, or securities advice should come from licensed professionals."],
  ["What does it cost to start?", "The first two months are free. There is no commitment during that period. After the pilot, we scope a paid services engagement only if you want to continue."],
  ["Where are you based?", "We are based in Toronto. Most of our current work serves Toronto clients and China clients, with North American partners available for fulfillment, customer service, compliance, and local execution when needed."],
  ["How do you make content easier to find on Google and AI search?", "We write pages and blog posts around specific client questions, locations, and services so search engines and AI answer engines can understand what JYDream does: Toronto digital operations consulting, customer service workflows, accessory reminder systems, and China company overseas expansion support."],
  ["Do you sign NDAs?", "Yes, mutual NDA before any discovery call. We routinely handle confidential financials, supplier relationships, and IP roadmaps."],
];
---

<section class="ld-section" id="faq">
  <div class="ld-container">
    <div class="section-head" style="text-align: center; margin: 0 auto 56px;">
      <span class="eyebrow" style="justify-content: center;">FAQ</span>
      <h2 class="section-title">Questions, <em>answered plainly</em>.</h2>
    </div>
    <div class="faq-wrap" data-role="faq-wrap">
      {faqs.map(([q, a], i) => (
        <div class:list={["faq-item", i === 0 && "open"]}>
          <button class="faq-q" type="button">
            <span>{q}</span>
            <span class="faq-q-icon"><Icons name="plus" /></span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">{a}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLDivElement>(".faq-item").forEach((item) => {
    const q = item.querySelector<HTMLButtonElement>(".faq-q");
    q?.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      item.parentElement
        ?.querySelectorAll(".faq-item")
        .forEach((el) => el.classList.remove("open"));
      if (!isOpen) item.classList.add("open");
    });
  });
</script>
