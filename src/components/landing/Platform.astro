---
const ints: [string, string][] = [
  ["Shopify", "#95BF47"],
  ["Amazon", "#FF9900"],
  ["Stripe", "#635BFF"],
  ["Twilio", "#F22F46"],
  ["Resend", "#000000"],
  ["Google", "#4285F4"],
  ["Slack", "#4A154B"],
  ["Clerk", "#6C47FF"],
  ["Vercel", "#000000"],
  ["OpenAI", "#10A37F"],
  ["Gemini", "#4285F4"],
  ["Claude", "#C15F3C"],
];
---

<section class="ld-section ld-section-tight" id="platform">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">JYDream Dashboard</span>
        <h2 class="section-title">
          A dashboard for the engagement, <em>not a SaaS pitch</em>.
        </h2>
        <p class="section-sub">
          The Dashboard is included in our consulting service. It gives your
          team one place to see tasks, channel readiness, customer issues,
          partner notes, and weekly decisions while JYDream does the work with
          you.
        </p>
      </div>
      <a class="btn btn-ghost" href="#cta">See it in a consult →</a>
    </div>
    <div class="int-grid">
      {ints.map(([name, color]) => (
        <div class="int-cell">
          <div class="int-logo" style={`background: ${color};`}>{name[0]}</div>
          <span>{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
