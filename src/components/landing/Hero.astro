---
import Icons from "./Icons.astro";
---

<section class="hero" id="top">
  <div class="hero-grain"></div>
  <div class="ld-container hero-inner">
    <div class="hero-top">
      <span class="pill pill-coral">
        <span class="dot"></span>Toronto-based · Serving Toronto businesses and China exporters
      </span>
    </div>
    <div class="hero-grid">
      <div>
        <h1 class="hero-title">
          Practical systems for <em>local growth and overseas expansion</em>.
        </h1>
        <p class="hero-sub">
          JYDream helps Toronto service businesses and China-based companies
          fix the messy parts of growth: websites, customer service, sales
          follow-up, accessory reminders, tax/accounting partner coordination,
          and North America market entry.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary btn-lg" href="#cta">
            Start with 2 free months <Icons name="arrow" />
          </a>
          <a class="btn btn-ghost btn-lg" href="#client-work">See client work</a>
        </div>
        <div class="hero-fine">
          First 2 months free · No commitment · NDA on request
        </div>

        <div class="hero-points">
          <span>Toronto service businesses</span>
          <span>China exporters</span>
          <span>Tax/accounting partner coordination</span>
        </div>
      </div>

      <div class="hero-mocks">
        <div class="hero-offer">
          <span class="offer-kicker">Start here</span>
          <div class="offer-price">$0</div>
          <h2>First 2 months free.</h2>
          <p>
            Pick one messy workflow. We build the first version with you before
            you commit to a paid engagement.
          </p>
          <ul>
            <li>Website leads and sales follow-up</li>
            <li>Customer service and accessory reminders</li>
            <li>China export readiness or partner coordination</li>
          </ul>
          <a class="btn btn-primary btn-lg" href="/contact">
            Start free <Icons name="arrow" />
          </a>
          <div class="offer-fine">No commitment · Mutual NDA on request</div>
        </div>
      </div>
    </div>
  </div>
</section>
