---
import Icons from "./Icons.astro";
---

<section class="hero" id="top">
  <div class="hero-grain"></div>
  <div class="ld-container hero-inner">
    <div class="hero-top">
      <span class="pill pill-coral">
        <span class="dot"></span>Now onboarding overseas expansion pilots for 2026
      </span>
    </div>
    <div class="hero-grid">
      <div>
        <h1 class="hero-title">
          Consulting partner for <em>overseas expansion</em>.
        </h1>
        <p class="hero-sub">
          JYDream helps Asian companies enter and scale in the US &amp; Canada.
          The work is consulting-led: market entry services, the JYDream
          Dashboard for shared visibility, and local operating experience from
          people who know the region.
        </p>
        <div class="hero-ctas">
          <a class="btn btn-primary btn-lg" href="#cta">
            Start with 2 free months <Icons name="arrow" />
          </a>
          <a class="btn btn-ghost btn-lg" href="#articles">Read field notes</a>
        </div>
        <div class="hero-fine">
          Free first 2 months · No commitment · NDA on request
        </div>

        <div class="vs-cards" data-role="vs-cards">
          <button
            type="button"
            class="vs-card active"
            data-vertical="commerce"
          >
            <span class="vs-card-icon"><Icons name="box" size={12} /></span>
            <span class="vs-card-label">We need</span>
            <span class="vs-card-title">Market entry services</span>
            <span class="vs-card-desc">Positioning, channels, compliance, and launch execution</span>
          </button>
          <button
            type="button"
            class="vs-card"
            data-vertical="service"
          >
            <span class="vs-card-icon"><Icons name="wrench" size={12} /></span>
            <span class="vs-card-label">We need</span>
            <span class="vs-card-title">Local operations support</span>
            <span class="vs-card-desc">Customer service, partners, aftersales, and local judgment</span>
          </button>
        </div>
      </div>

      <div class="hero-mocks">
        <div class="mock-window mock-commerce">
          <div class="mw-bar">
            <div class="mw-dots"><span class="mw-dot"></span><span class="mw-dot"></span><span class="mw-dot"></span></div>
            <div class="mw-url">dashboard.jydream.ca · client: Altura</div>
            <span class="sync-pill">JYDream Dashboard</span>
          </div>
          <div class="cdash-inner">
            <div class="cdash-top">
              <div>
                <div class="cdash-title">Overseas expansion · Weekly brief</div>
                <div class="cdash-sub">Week 4 · US + CA · pilot scope</div>
              </div>
              <span class="pill pill-coral"><span class="dot dot-green"></span>On track</span>
            </div>
            <div class="cdash-stats">
              <div class="cstat"><div class="cstat-label">Pilot tasks</div><div class="cstat-val">18</div><div class="cstat-delta">12 done</div></div>
              <div class="cstat"><div class="cstat-label">Channels ready</div><div class="cstat-val">3</div><div class="cstat-delta">Amazon · DTC · B2B</div></div>
              <div class="cstat"><div class="cstat-label">Open blockers</div><div class="cstat-val">2</div><div class="cstat-delta neg">Need approval</div></div>
            </div>
            <div class="ctable">
              <div class="ctable-head">
                <span>Workstream</span><span>Owner</span><span>Region</span><span>Status</span>
              </div>
              <div class="ctable-row">
                <div>
                  <div class="name">Market positioning memo</div>
                  <div class="sku">Services</div>
                </div>
                <div class="chan">
                  <span class="ch-badge shop">JYDream</span>
                </div>
                <div class="price">US</div>
                <div><span class="sync-pill">Done</span></div>
              </div>
              <div class="ctable-row">
                <div>
                  <div class="name">Compliance checklist</div>
                  <div class="sku">Local experience</div>
                </div>
                <div class="chan">
                  <span class="ch-badge amzn">Partner</span>
                </div>
                <div class="price">US + CA</div>
                <div><span class="sync-pill">Done</span></div>
              </div>
              <div class="ctable-row">
                <div>
                  <div class="name">First-channel pilot</div>
                  <div class="sku">Dashboard</div>
                </div>
                <div class="chan">
                  <span class="ch-badge shop">Client</span>
                  <span class="ch-badge amzn">JYDream</span>
                </div>
                <div class="price">CA</div>
                <div><span class="sync-pill">Live</span></div>
              </div>
            </div>
          </div>
        </div>

        <div class="mock-window mock-service">
          <div class="mw-bar">
            <div class="mw-dots"><span class="mw-dot"></span><span class="mw-dot"></span><span class="mw-dot"></span></div>
            <div class="mw-url">dashboard.jydream.ca · local queue</div>
          </div>
          <div class="sdash-inner">
            <div class="sdash-top">
              <div class="sdash-title">Local experience queue · This week</div>
              <span class="sdash-badge">7 due</span>
            </div>
            <div class="sdash-row">
              <div class="sdash-ava">LS</div>
              <div class="sdash-meta">
                <div class="sdash-name">Lucía Salas · Toronto</div>
                <div class="sdash-desc">Water filter · due today</div>
              </div>
              <div class="sdash-status confirmed">Confirmed</div>
            </div>
            <div class="sdash-row">
              <div class="sdash-ava">JM</div>
              <div class="sdash-meta">
                <div class="sdash-name">Jin Mercado · Seattle</div>
                <div class="sdash-desc">Heater element · +3 days</div>
              </div>
              <div class="sdash-status sent">SMS sent</div>
            </div>
            <div class="sdash-row">
              <div class="sdash-ava">OK</div>
              <div class="sdash-meta">
                <div class="sdash-name">Owen Kim · Vancouver</div>
                <div class="sdash-desc">O-ring set · +7 days</div>
              </div>
              <div class="sdash-status pending">Queued</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
