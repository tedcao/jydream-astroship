---
const commerce = [
  ["Diagnose", "Weeks 1–2. We audit your category, current overseas readiness, competition, and channel options. You get a practical first-move memo."],
  ["Pilot", "Weeks 3–8. We run a focused pilot at no cost: positioning, first-channel setup, dashboard reporting, or a local customer workflow."],
  ["Decide", "After month 2. Continue with a scoped services engagement, hand the work back to your team, or stop. No commitment during the free pilot."],
];
const service = [
  ["Diagnose", "Weeks 1–2. We map install friction, warranty risk, consumable patterns, and what local customers will expect after purchase."],
  ["Pilot", "Weeks 3–8. We test a local service workflow: support scripts, partner handoff, parts logic, and dashboard visibility for your team."],
  ["Decide", "After month 2. Continue only if the pilot proves useful. The first two months are free and there is no commitment to stay."],
];
---

<section class="ld-section ld-section-tight" id="how-it-works" style="background: var(--bg-sunken);">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">Engagement model</span>
        <h2 class="section-title">
          Start free for 2 months. <em>Continue only if it works.</em>
        </h2>
        <p class="section-sub" data-hiw-sub data-copy-commerce="A simple pilot path for product brands expanding overseas." data-copy-service="A simple pilot path for serviced products expanding overseas.">
          A simple pilot path for product brands expanding overseas.
        </p>
      </div>
      <div class="v-toggle" data-role="v-toggle">
        <button type="button" data-vertical="commerce" class="active">Product</button>
        <button type="button" data-vertical="service">Serviced</button>
      </div>
    </div>
    <div class="how-grid" data-role="how-grid-commerce">
      {commerce.map(([title, body], i) => (
        <div class="how-step">
          <div class="how-num">0{i + 1}</div>
          <h3 class="how-title">{title}</h3>
          <p class="how-body">{body}</p>
        </div>
      ))}
    </div>
    <div class="how-grid" data-role="how-grid-service" style="display: none;">
      {service.map(([title, body], i) => (
        <div class="how-step">
          <div class="how-num">0{i + 1}</div>
          <h3 class="how-title">{title}</h3>
          <p class="how-body">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
