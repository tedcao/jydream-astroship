---
const commerce = [
  ["Diagnose", "Weeks 1–3. We audit your category, competition, and readiness for NA. You get a go/no-go memo with a ranked channel plan."],
  ["Baseline", "Weeks 4–10. Entity, tax, compliance, 3PL, Amazon + Shopify setup, creative in NA voice. Your NA instance, our hands."],
  ["Operate", "Month 3 onward. We run the daily ops — orders, CS, ads, content. You get a weekly brief and a quarterly strategy review."],
];
const service = [
  ["Diagnose", "Weeks 1–3. Warranty claims, install friction, consumable patterns. We map what breaks when NA customers use your product."],
  ["Baseline", "Weeks 4–12. Entity + product certifications (FDA/CSA/UL), NA 3PL partners onboarded, consumable SKUs set up for recurring fulfillment."],
  ["Operate", "Month 4 onward. We ship consumables on schedule, handle warranty & returns, and keep every customer in one record. You see it all in one dashboard."],
];
---

<section class="ld-section ld-section-tight" id="how-it-works" style="background: var(--bg-sunken);">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">Engagement model</span>
        <h2 class="section-title">
          Live in a quarter. <em>Operated for the long haul.</em>
        </h2>
        <p class="section-sub" data-hiw-sub data-copy-commerce="A three-phase engagement — same shape for consumer brands." data-copy-service="A three-phase engagement — same shape for serviced-equipment makers.">
          A three-phase engagement — same shape for consumer brands.
        </p>
      </div>
      <div class="v-toggle" data-role="v-toggle">
        <button type="button" data-vertical="commerce" class="active">Consumer</button>
        <button type="button" data-vertical="service">Serviced</button>
      </div>
    </div>
    <div class="how-grid" data-role="how-grid-commerce">
      {commerce.map(([title, body], i) => (
        <div class="how-step">
          <div class="how-num">0{i + 1}</div>
          <h3 class="how-title">{title}</h3>
          <p class="how-body">{body}</p>
        </div>
      ))}
    </div>
    <div class="how-grid" data-role="how-grid-service" style="display: none;">
      {service.map(([title, body], i) => (
        <div class="how-step">
          <div class="how-num">0{i + 1}</div>
          <h3 class="how-title">{title}</h3>
          <p class="how-body">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
