---
type LinkItem = [string, string];
type Col = [string, LinkItem[]];
const cols: Col[] = [
  ["Services", [["Consulting services", "/services"], ["JYDream Dashboard", "/dashboard"], ["Client work", "/client-work"], ["Pricing", "/pricing"]]],
  ["Who we serve", [["Toronto businesses", "/toronto-business-consulting"], ["China exporters", "/china-export-consulting"], ["WaterDoctor.ca work", "/client-work"], ["FAQ", "/faq"]]],
  ["Company", [["About", "/about"], ["Blog", "/blog"], ["Contact", "/contact"], ["Privacy", "/privacy-policy"]]],
  ["Start", [["2 months free", "/contact"], ["Book a consult", "/contact"], ["Terms", "/terms"], ["Email us", "mailto:ted@jydream.ca"]]],
];
const year = new Date().getFullYear();
---

<footer class="ld-footer">
  <div class="ld-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="#top">
          <span class="logo-mark"><span>J</span></span>JYDream
        </a>
        <p class="footer-brand-desc">
          Toronto-based consulting partner serving local Toronto businesses and
          China-based companies expanding overseas. We combine services, the
          JYDream Dashboard, and local operating experience.
        </p>
      </div>
      {cols.map(([title, links]) => (
        <div class="footer-col">
          <div class="footer-col-title">{title}</div>
          {links.map(([label, href]) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <div>© {year} JYDream Partners · Consulting services for overseas expansion</div>
      <div class="footer-social">
        <a href="mailto:ted@jydream.ca" aria-label="Email">Email</a>
        <a href="https://wa.me/16475537802" aria-label="WhatsApp">WhatsApp</a>
      </div>
      <div>
        <a href="/privacy-policy" style="color: inherit; font-size: 13px;">Privacy Policy</a>
        <span style="color: inherit; font-size: 13px;"> · </span>
        <a href="/terms" style="color: inherit; font-size: 13px;">Terms</a>
      </div>
    </div>
  </div>
</footer>
