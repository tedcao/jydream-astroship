---
import Icons from "./Icons.astro";

type Col = [string, string[]];
const cols: Col[] = [
  ["Solutions", ["Consulting services", "JYDream Dashboard", "Tax/accounting partners", "Capital-market readiness", "Local experience"]],
  ["Who we serve", ["Toronto local businesses", "China exporters", "Product brands", "Serviced products", "B2B factories"]],
  ["Company", ["About", "Blog", "Articles", "Partners", "Privacy"]],
  ["Contact", ["Start free for 2 months", "Book a consult", "Toronto", "China clients", "NDA & legal"]],
];
const year = new Date().getFullYear();
---

<footer class="ld-footer">
  <div class="ld-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="#top">
          <span class="logo-mark"><span>J</span></span>JYDream
        </a>
        <p class="footer-brand-desc">
          Toronto-based consulting partner serving local Toronto businesses and
          China-based companies expanding overseas. We combine services, the
          JYDream Dashboard, and local operating experience.
        </p>
      </div>
      {cols.map(([title, links]) => (
        <div class="footer-col">
          <div class="footer-col-title">{title}</div>
          {links.map((l) => (
            <a href="#">{l}</a>
          ))}
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <div>© {year} JYDream Partners · Consulting services for overseas expansion</div>
      <div class="footer-social">
        <a href="#" aria-label="LinkedIn"><Icons name="linkedin" /></a>
        <a href="#" aria-label="Twitter"><Icons name="twitter" /></a>
        <a href="#" aria-label="YouTube"><Icons name="youtube" /></a>
      </div>
      <div>
        <a href="/privacy-policy" style="color: inherit; font-size: 13px;">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
