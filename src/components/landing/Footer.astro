---
import Icons from "./Icons.astro";

type Col = [string, string[]];
const cols: Col[] = [
  ["Services", ["Market entry", "Operations", "Customer service", "Aftermarket & service", "Platform"]],
  ["Who we serve", ["Consumer brands", "Serviced equipment", "Industrial B2B", "Multi-brand corporates"]],
  ["Company", ["About", "Team", "Careers", "Partners", "Press"]],
  ["Contact", ["Book a consult", "Toronto office", "Shenzhen office", "Seattle office", "NDA & legal"]],
];
const year = new Date().getFullYear();
---

<footer class="ld-footer">
  <div class="ld-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="#top">
          <span class="logo-mark"><span>J</span></span>JYDream
        </a>
        <p class="footer-brand-desc">
          Cross-border operations partner for Asian brands and corporates
          expanding into the US &amp; Canada. We run your North American
          business so you can keep building the product.
        </p>
      </div>
      {cols.map(([title, links]) => (
        <div class="footer-col">
          <div class="footer-col-title">{title}</div>
          {links.map((l) => (
            <a href="#">{l}</a>
          ))}
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <div>© {year} JYDream Partners · A services firm, not a SaaS</div>
      <div class="footer-social">
        <a href="#" aria-label="LinkedIn"><Icons name="linkedin" /></a>
        <a href="#" aria-label="Twitter"><Icons name="twitter" /></a>
        <a href="#" aria-label="YouTube"><Icons name="youtube" /></a>
      </div>
      <div>
        <a href="/privacy-policy" style="color: inherit; font-size: 13px;">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
