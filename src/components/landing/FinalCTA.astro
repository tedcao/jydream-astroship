---
import Icons from "./Icons.astro";
---

<section class="ld-section" id="cta">
  <div class="ld-container">
    <div class="final-cta">
      <h2 class="final-cta-title">
        Ship in North America without hiring a team there.
      </h2>
      <p class="final-cta-sub">
        30-minute consult. Free market-entry readiness review. NDA on request.
      </p>
      <div class="final-cta-ctas">
        <a class="btn btn-primary btn-lg" href="/contact">
          Book a consult <Icons name="arrow" />
        </a>
        <a class="btn btn-ghost btn-lg" href="#case-studies">See a case study</a>
      </div>
      <div class="final-cta-fine">Partners · Toronto · Shenzhen · Seattle</div>
    </div>
  </div>
</section>
