---
type Work = {
  title: string;
  meta: string;
  body: string;
  initials: string;
  color: string;
  href?: string;
};

const work: Work[] = [
  {
    title: "WaterDoctor.ca",
    meta: "Toronto client · Water service business",
    body:
      "We helped build their website, customer service workflow, sales support, and accessory reminder system so local customers can book, ask questions, and receive timely replacement reminders.",
    initials: "WD",
    color: "#2563EB",
    href: "https://waterdoctor.ca",
  },
  {
    title: "Mozu Doll",
    meta: "China factory · Overseas-facing brand",
    body:
      "We supported the digital foundation for a Chinese manufacturing brand preparing for overseas buyers, including web presence, product presentation, and export-oriented customer touchpoints.",
    initials: "MZ",
    color: "#FF6B5B",
    href: "https://mozudoll.com",
  },
  {
    title: "JY Doll",
    meta: "China factory · Cross-border sales support",
    body:
      "We helped another China-based doll manufacturer improve its overseas-facing presence and prepare sales materials for non-domestic customers.",
    initials: "JY",
    color: "#14B8A6",
    href: "https://jydoll.com",
  },
  {
    title: "Confidential China exporters",
    meta: "China clients · Overseas expansion advisory",
    body:
      "For other China-based companies, we support market-entry planning, English-language positioning, channel readiness, and practical Toronto / North America operating advice.",
    initials: "CN",
    color: "#6366F1",
  },
];
---

<section class="ld-section" id="client-work" style="background: var(--bg-sunken);">
  <div class="ld-container">
    <div class="features-head">
      <div>
        <span class="eyebrow">Selected client work</span>
        <h2 class="section-title">Toronto clients and <em>China exporters</em>.</h2>
        <p class="section-sub">
          We are based in Toronto and mainly serve local Toronto businesses and
          China-based companies preparing for overseas markets. These are real
          examples and representative confidential work, not invented logos.
        </p>
      </div>
    </div>
    <div class="test-grid">
      {work.map((item) => (
        <article class="test-card">
          <div class="test-work-title">{item.title}</div>
          <p class="test-work-body">{item.body}</p>
          <div class="test-person">
            <div class="test-ava" style={`background: ${item.color};`}>{item.initials}</div>
            <div>
              <div class="test-name">{item.meta}</div>
              {item.href && (
                <a class="test-role test-link" href={item.href} target="_blank" rel="noopener">
                  {item.href.replace("https://", "")}
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
