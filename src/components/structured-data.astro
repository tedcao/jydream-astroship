---
export interface Props {
  type: 'blog' | 'organization' | 'website';
  data?: any;
}

const { type, data } = Astro.props;

let structuredData = {};

if (type === 'blog' && data) {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": data.title,
    "description": data.snippet,
    "author": {
      "@type": "Organization",
      "name": data.author || "JYDream Team"
    },
    "publisher": {
      "@type": "Organization",
      "name": "JYDream",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.jydream.ca/favicon.svg"
      }
    },
    "datePublished": data.publishDate,
    "dateModified": data.publishDate,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": Astro.url.href
    }
  };
} else if (type === 'organization') {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "JYDream",
    "url": "https://www.jydream.ca",
    "logo": "https://www.jydream.ca/favicon.svg",
    "description": "Toronto-based consulting partner for local service businesses and China exporters, helping with websites, customer service workflows, sales support, accessory reminders, tax partner coordination, and North America expansion.",
    "areaServed": ["Toronto", "Ontario", "Canada", "China", "United States"],
    "knowsAbout": [
      "Toronto service business websites",
      "customer service workflow",
      "accessory reminder systems",
      "China exporter overseas expansion",
      "GEO and AI search content",
      "US and Canada tax partner coordination",
      "Nasdaq listing readiness",
      "capital market readiness"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+1-647-553-7802",
      "email": "ted@jydream.ca",
      "contactType": "customer service",
      "areaServed": ["CA", "US", "CN"],
      "availableLanguage": ["English", "Chinese"]
    }
  };
} else if (type === 'website') {
  structuredData = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "JYDream",
    "url": "https://www.jydream.ca",
    "description": "Toronto-based consulting partner for local service businesses and China exporters, helping with websites, customer service workflows, sales support, accessory reminders, tax partner coordination, and North America expansion.",
    "about": [
      "Toronto digital operations consulting",
      "China company overseas expansion",
      "customer service workflows",
      "accessory reminder systems",
      "GEO and AI search content",
      "tax and accounting partner coordination",
      "capital market readiness"
    ],
    "publisher": {
      "@type": "Organization",
      "name": "JYDream"
    },
    "hasPart": [
      { "@type": "WebPage", "name": "Services", "url": "https://www.jydream.ca/services/" },
      { "@type": "WebPage", "name": "Toronto Business Consulting", "url": "https://www.jydream.ca/toronto-business-consulting/" },
      { "@type": "WebPage", "name": "China Export Consulting", "url": "https://www.jydream.ca/china-export-consulting/" },
      { "@type": "WebPage", "name": "Client Work", "url": "https://www.jydream.ca/client-work/" },
      { "@type": "WebPage", "name": "JYDream Dashboard", "url": "https://www.jydream.ca/dashboard/" },
      { "@type": "WebPage", "name": "Blog", "url": "https://www.jydream.ca/blog/" },
      { "@type": "WebPage", "name": "FAQ", "url": "https://www.jydream.ca/faq/" },
      { "@type": "ContactPage", "name": "Contact", "url": "https://www.jydream.ca/contact/" }
    ]
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
