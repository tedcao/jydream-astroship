---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import StructuredData from "@components/structured-data.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  structuredData?: any;
  landing?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title, description, structuredData, landing = false } = Astro.props;

const makeTitle = title
  ? title + " | " + "JYDream"
  : "JYDream - Toronto Digital Operations & China Export Consulting";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={description || "JYDream is a Toronto-based consulting partner for local service businesses and China exporters, helping with websites, customer service workflows, sales follow-up, accessory reminders, tax partner coordination, and North America expansion."}
      canonical={canonicalURL}
      twitter={{
        creator: "@jydream",
        site: "@jydream",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `JYDream - Toronto Digital Operations & China Export Consulting`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "JYDream Toronto digital operations and China export consulting",
        },
      }}
    />
    <StructuredData type="website" />
    <StructuredData type="organization" />
    {structuredData && <StructuredData type="blog" data={structuredData} />}
  </head>
  <body class:list={[landing && "landing"]}>
    {!landing && <Navbar />}
    <slot />
    {!landing && <Footer />}
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
