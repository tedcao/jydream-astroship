---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";

const services = [
  {
    title: "Website leads and sales follow-up",
    audience: "Toronto service businesses",
    pain: "Visitors arrive, but the business does not have a clean path for inquiry, qualification, owner review, and follow-up.",
    work: ["Website structure", "Lead capture forms", "Sales status tracking", "Weekly follow-up notes"],
  },
  {
    title: "Customer service workflow",
    audience: "Local businesses and product teams",
    pain: "Customer questions are scattered across calls, email, WhatsApp, forms, and staff memory.",
    work: ["FAQ structure", "Service request intake", "Customer notes", "Open issue tracking"],
  },
  {
    title: "Accessory and replacement reminders",
    audience: "Service and product businesses",
    pain: "Recurring revenue is lost because service timing, accessory replacement, or reorder reminders are manual.",
    work: ["Reminder rules", "Customer segmentation", "Message timing", "Dashboard visibility"],
  },
  {
    title: "China export readiness",
    audience: "China factories and brands",
    pain: "The product may be strong, but North America buyers need clearer English materials, trust signals, and inquiry workflows.",
    work: ["English website planning", "Product page structure", "B2B inquiry flow", "Buyer-facing sales materials"],
  },
  {
    title: "GEO and AI search readiness",
    audience: "Companies that need to be found clearly",
    pain: "Search engines and AI answer systems cannot understand the business if the website only says generic things.",
    work: ["Service pages", "FAQ content", "Location signals", "Question-led blog topics"],
  },
  {
    title: "Partner and capital-market coordination",
    audience: "Owners planning bigger moves",
    pain: "Expansion questions often become tax, accounting, compliance, financing, or listing-readiness questions.",
    work: ["Question preparation", "Accountant/tax partner coordination", "Operating notes", "Capital-market context"],
  },
];
---

<Layout
  title="Services"
  description="JYDream services for Toronto businesses and China exporters: websites, customer service workflows, sales follow-up, accessory reminders, GEO content, tax/accounting partner coordination, and North America market-entry support."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Services for local growth and overseas expansion.</Fragment>
      <Fragment slot="desc">
        We help owners fix the practical parts of growth: customer intake,
        follow-up, reminders, overseas-facing content, partner coordination, and
        owner visibility.
      </Fragment>
    </Sectionhead>

    <section class="mx-auto mt-16 grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article class="rounded-lg border border-gray-200 bg-white p-6">
            <div class="text-xs font-semibold uppercase tracking-wide text-[#F04E3E]">
              {service.audience}
            </div>
            <h2 class="mt-3 text-xl font-semibold tracking-tight text-gray-900">
              {service.title}
            </h2>
            <p class="mt-3 leading-relaxed text-slate-600">{service.pain}</p>
            <div class="mt-5 border-t border-gray-100 pt-4">
              <div class="text-sm font-semibold text-gray-900">Typical work</div>
              <ul class="mt-3 space-y-2 text-sm text-slate-600">
                {service.work.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </article>
        ))
      }
    </section>

    <section class="mx-auto mt-16 grid max-w-5xl gap-5 md:grid-cols-2">
      <a
        href="/toronto-business-consulting"
        class="rounded-lg border border-gray-200 bg-gray-50 p-6 transition hover:border-gray-300">
        <div class="text-sm font-semibold uppercase tracking-wide text-[#F04E3E]">
          Toronto
        </div>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-gray-900">
          Consulting for Toronto service businesses
        </h2>
        <p class="mt-3 leading-relaxed text-slate-600">
          Lead capture, customer service, sales follow-up, reminders, and owner
          visibility for local operators.
        </p>
      </a>
      <a
        href="/china-export-consulting"
        class="rounded-lg border border-gray-200 bg-gray-50 p-6 transition hover:border-gray-300">
        <div class="text-sm font-semibold uppercase tracking-wide text-[#F04E3E]">
          China exporters
        </div>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-gray-900">
          Consulting for China companies expanding overseas
        </h2>
        <p class="mt-3 leading-relaxed text-slate-600">
          English websites, product presentation, buyer workflows, partner
          questions, and North America readiness.
        </p>
      </a>
    </section>

    <section class="mx-auto mt-16 max-w-5xl rounded-lg border border-gray-200 bg-gray-50 p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
            The first step is free.
          </h2>
          <p class="mt-3 leading-relaxed text-slate-600">
            Pick one workflow. We build the first useful version during a
            two-month pilot before you decide whether to continue.
          </p>
        </div>
        <Link href="/contact">Start free pilot</Link>
      </div>
    </section>
  </Container>
</Layout>
