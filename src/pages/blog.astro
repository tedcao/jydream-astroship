---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";

const publishedBlogEntries = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

publishedBlogEntries.sort(function (a, b) {
  return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});

const featured = publishedBlogEntries[0];
const remaining = publishedBlogEntries.slice(1);

const topics = [
  "Toronto service business workflows",
  "China exporter readiness",
  "Customer service and sales follow-up",
  "Accessory reminders",
  "Tax/accounting partner coordination",
  "GEO and AI search content",
];
---

<Layout
  title="Blog"
  description="JYDream blog and field notes for Toronto service businesses and China exporters, covering websites, customer service workflows, sales follow-up, accessory reminders, GEO content, tax/accounting partner coordination, and North America market-entry support."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Resources for Toronto businesses and China exporters.</Fragment>
      <Fragment slot="desc">
        Short, practical articles based on the questions clients actually ask
        before they improve a website, workflow, reminder system, or overseas
        market-entry plan.
      </Fragment>
    </Sectionhead>

    <section class="mx-auto mt-12 flex max-w-5xl flex-wrap justify-center gap-3">
      {
        topics.map((topic) => (
          <span class="rounded-full border border-gray-200 bg-white px-4 py-2 text-sm text-slate-700">
            {topic}
          </span>
        ))
      }
    </section>

    {
      featured && (
        <section class="mx-auto mt-16 max-w-5xl">
          <a
            href={`/blog/${featured.slug}`}
            class="grid gap-8 rounded-lg border border-gray-200 bg-white p-5 transition hover:border-gray-300 md:grid-cols-[0.9fr_1.1fr] md:p-6">
            <Picture
              src={featured.data.image.src}
              alt={featured.data.image.alt}
              sizes="(max-width: 800px) 100vw, 800px"
              width={800}
              height={600}
              loading="eager"
              decoding="sync"
              class="h-full min-h-72 w-full rounded-lg bg-white object-cover object-center"
            />
            <div class="flex flex-col justify-center">
              <div class="text-sm font-semibold uppercase tracking-wide text-[#F04E3E]">
                Featured field note
              </div>
              <h2 class="mt-3 text-3xl font-semibold leading-tight tracking-tight text-gray-900">
                {featured.data.title}
              </h2>
              <p class="mt-4 leading-relaxed text-slate-600">
                {featured.data.snippet}
              </p>
              <div class="mt-5 flex flex-wrap gap-2 text-sm text-slate-500">
                <span>{featured.data.category}</span>
                <span>·</span>
                <time datetime={featured.data.publishDate.toISOString()}>
                  {featured.data.publishDate.toDateString()}
                </time>
              </div>
            </div>
          </a>
        </section>
      )
    }

    <main class="mx-auto mt-16 max-w-5xl">
      <div class="grid gap-6 md:grid-cols-2">
        {
          remaining.map((blogPostEntry, index) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 transition hover:border-gray-300">
              <a href={`/blog/${blogPostEntry.slug}`}>
                <Picture
                  src={blogPostEntry.data.image.src}
                  alt={blogPostEntry.data.image.alt}
                  sizes="(max-width: 800px) 100vw, 600px"
                  width={600}
                  height={360}
                  loading={index <= 1 ? "eager" : "lazy"}
                  decoding={index <= 1 ? "sync" : "async"}
                  class="aspect-[5/3] w-full rounded-lg bg-white object-cover object-center"
                />
                <div class="mt-5">
                  <span class="text-xs font-semibold uppercase tracking-wide text-[#F04E3E]">
                    {blogPostEntry.data.category}
                  </span>
                  <h2 class="mt-2 text-2xl font-semibold leading-snug tracking-tight text-gray-900">
                    {blogPostEntry.data.title}
                  </h2>
                  <p class="mt-3 leading-relaxed text-slate-600">
                    {blogPostEntry.data.snippet}
                  </p>
                  <time
                    class="mt-4 block text-sm text-slate-400"
                    datetime={blogPostEntry.data.publishDate.toISOString()}>
                    {blogPostEntry.data.publishDate.toDateString()}
                  </time>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </main>

    <section class="mx-auto mt-16 max-w-5xl rounded-lg border border-gray-200 bg-gray-50 p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
            Need content around your own customer questions?
          </h2>
          <p class="mt-3 leading-relaxed text-slate-600">
            We can turn service questions, buyer objections, and local market
            context into website pages and blog topics that help people, Google,
            and AI answer engines understand your business.
          </p>
        </div>
        <Link href="/contact">Start free pilot</Link>
      </div>
    </section>
  </Container>
</Layout>
