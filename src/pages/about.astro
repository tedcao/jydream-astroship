---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

// Filter team entries with 'draft: false' & date before current date
const publishedTeamMembers = await getCollection("team", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
---

<Layout
  title="About"
  description="JYDream is a consulting partner for Asian companies expanding overseas into the US and Canada."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">About JYDream</Fragment>
      <Fragment slot="desc">Consulting services, Dashboard visibility, and local experience for companies expanding overseas.</Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">
        Helping companies enter North America with fewer blind spots.
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        JYDream is a consulting services firm for Asian companies expanding
        overseas, with a practical focus on the US and Canada. We help teams
        move from "we should go overseas" to a clear plan, a focused pilot, and
        local execution that customers and partners can trust.
      </p>
      <p class="text-lg leading-relaxed text-slate-500 mt-4">
        Our solution has three parts: consulting services, the JYDream Dashboard,
        and local experience. The services cover strategy, channel launch,
        compliance coordination, customer experience, and operating reviews. The
        Dashboard keeps the work visible. The local experience helps translate
        decisions into the habits, standards, and expectations of North American
        buyers.
      </p>
      <p class="text-lg leading-relaxed text-slate-500 mt-4">
        We start with a free two-month pilot and no commitment. That gives both
        sides enough time to test the relationship with real work before
        deciding whether a longer services engagement makes sense.
      </p>
    </div>
