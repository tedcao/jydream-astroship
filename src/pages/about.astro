---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

// Filter team entries with 'draft: false' & date before current date
const publishedTeamMembers = await getCollection("team", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
---

<Layout
  title="About"
  description="JYDream is a Toronto-based consulting partner for local service businesses and China exporters."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">About JYDream</Fragment>
      <Fragment slot="desc">Toronto-based consulting for local service businesses and China exporters.</Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">
        Helping owners make growth less messy.
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        JYDream is a Toronto-based consulting and implementation partner. We
        mainly serve local Toronto businesses that need cleaner digital
        operations, and China-based companies preparing for overseas markets.
      </p>
      <p class="text-lg leading-relaxed text-slate-500 mt-4">
        We help with websites, customer service workflows, sales support,
        accessory reminder systems, English product presentation, and North
        America expansion planning. When tax, accounting, or capital-market
        questions appear, we coordinate the discussion with global accountant
        and tax partners so licensed professionals can advise where needed.
      </p>
      <p class="text-lg leading-relaxed text-slate-500 mt-4">
        We start with a free two-month pilot and no commitment. That gives both
        sides enough time to test the relationship with real work before
        deciding whether a longer services engagement makes sense.
      </p>
    </div>
