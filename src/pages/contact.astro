---
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Contactform from "@components/contactform.astro";
---

<Layout
  title="Contact"
  description="Contact JYDream to start a free two-month overseas expansion pilot with no commitment."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact Us</Fragment>
      <Fragment slot="desc">Start with a free two-month overseas expansion pilot. No commitment.</Fragment>
    </Sectionhead>

    <div class="mx-auto max-w-4xl mt-16">
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <h2 class="font-medium text-2xl text-gray-800">Talk with JYDream</h2>
          <p class="text-lg leading-relaxed text-slate-500 mt-3">
            Tell us what you are trying to do overseas, where you are in the
            process, and what is blocking progress. We will use the first call
            to decide whether a free two-month pilot is a useful next step.
          </p>
          <div class="mt-5">
            <div class="flex items-center mt-2 space-x-2 text-gray-600">
              <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
                href="mailto:ted@jydream.ca"
                >ted@jydream.ca</a
              >
            </div>
            <div class="flex items-center mt-2 space-x-2 text-gray-600">
              <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
                href="tel:+16475537802">+1 (647) 553-7802</a
              >
            </div>
            <div class="flex items-center mt-2 space-x-2 text-gray-600">
              <Icon class="text-gray-400 w-4 h-4" name="uil:whatsapp" /><a
                href="https://wa.me/16475537802">+1 (647) 553-7802</a
              >
            </div>
          </div>
        </div>
        <div>
          <Contactform />
        </div>
      </div>
    </div>
  </Container>
</Layout>
