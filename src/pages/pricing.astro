---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import PricingCard from "@components/pricing.astro";

const pricing = [
  {
    name: "Free Pilot",
    price: "$0",
    popular: true,
    features: [
      "First 2 months free",
      "No commitment to continue",
      "One focused business workflow",
      "JYDream Dashboard visibility",
      "Weekly working session",
      "Mutual NDA on request",
    ],
    button: {
      text: "Start free",
      link: "/contact",
    },
  },
  {
    name: "Consulting Services",
    price: "Scoped after pilot",
    popular: false,
    features: [
      "Website and lead workflow",
      "Customer service and sales support",
      "Accessory reminder system",
      "Tax/accounting partner coordination",
      "China export readiness",
      "Capital-market context",
    ],
    button: {
      text: "Book a consult",
      link: "/contact",
    },
  },
  {
    name: "Dashboard + Local Experience",
    price: "Included",
    popular: false,
    features: [
      "Shared JYDream Dashboard",
      "Local US + Canada operating notes",
      "Customer, channel, and partner tracking",
      "Read-only leadership visibility",
      "Monthly learning summary",
      "Clean handoff path",
    ],
    button: {
      text: "Talk to us",
      link: "/contact",
    },
  },
];
---

<Layout
  title="Start free for 2 months"
  description="Start a free two-month JYDream pilot for one focused workflow: website, customer service, sales follow-up, accessory reminders, China export readiness, or partner coordination."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Start free for 2 months.</Fragment>
      <Fragment slot="desc">
        Choose one workflow. If the pilot proves useful, we scope the next
        service engagement together.
      </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-(--breakpoint-lg) mt-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>
  </Container>
</Layout>
