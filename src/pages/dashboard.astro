---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";

const dashboardItems = [
  "Website inquiries and lead source",
  "Sales follow-up status",
  "Customer service notes",
  "Accessory, service, or replacement reminder timing",
  "Open tasks and owner decisions",
  "Partner questions around tax, accounting, setup, or financing",
];

const views = [
  {
    title: "Owner view",
    text: "See what needs attention without searching through emails, messages, spreadsheets, and staff notes.",
  },
  {
    title: "Working view",
    text: "Track the practical work JYDream is doing during the engagement: lead flow, content, service process, reminders, and blockers.",
  },
  {
    title: "Handoff view",
    text: "If you decide to bring work in-house, the notes and workflow are organized enough for your team to continue.",
  },
];
---

<Layout
  title="JYDream Dashboard"
  description="The JYDream Dashboard is a shared working layer for consulting clients, helping owners see leads, customer service notes, sales follow-up, accessory reminders, tasks, and partner questions."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">The Dashboard supports the consulting work.</Fragment>
      <Fragment slot="desc">
        It is not a standalone SaaS pitch. It is the shared operating layer we
        use so owners can see what is happening and decide what matters next.
      </Fragment>
    </Sectionhead>

    <section class="mx-auto mt-16 grid max-w-5xl gap-10 md:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-[#F04E3E]">
          Visibility without a heavy software rollout
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">
          Many businesses already have tools. They still lack one clear view.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600">
          The JYDream Dashboard helps collect the practical details around the
          engagement. It keeps the work grounded: who contacted the business,
          what needs follow-up, which reminder is due, what content is being
          prepared, and which partner question needs a decision.
        </p>
      </div>

      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <div class="text-sm font-semibold uppercase tracking-wide text-slate-500">
          What it can track
        </div>
        <ul class="mt-5 grid gap-3 text-slate-700">
          {dashboardItems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-5xl">
      <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
        Three practical views
      </h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {
          views.map((item) => (
            <article class="rounded-lg border border-gray-200 bg-white p-6">
              <h3 class="text-lg font-semibold text-gray-900">{item.title}</h3>
              <p class="mt-3 leading-relaxed text-slate-600">{item.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto mt-16 grid max-w-5xl gap-10 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
          What it is
        </h2>
        <p class="mt-4 leading-relaxed text-slate-600">
          A simple shared workspace for consulting execution, owner review, and
          weekly decisions.
        </p>
      </div>
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
          What it is not
        </h2>
        <p class="mt-4 leading-relaxed text-slate-600">
          A separate SaaS product we push before understanding the business. The
          service comes first; the dashboard only exists to make the service
          clearer.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-5xl rounded-lg border border-gray-200 bg-gray-50 p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
            See one workflow before committing.
          </h2>
          <p class="mt-3 leading-relaxed text-slate-600">
            The dashboard is included in the free two-month pilot when it helps
            the work stay visible.
          </p>
        </div>
        <Link href="/contact">Start free pilot</Link>
      </div>
    </section>
  </Container>
</Layout>
