---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// Get the entry directly from the prop on render
const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.snippet} structuredData={entry.data}>
  <Container>
    <div class="mx-auto max-w-3xl mt-14">
      <span class="text-[#F04E3E] uppercase tracking-wider text-sm font-medium">
        {entry.data.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight">
        {entry.data.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-gray-400">
          {entry.data.author}
        </span>
        <span class="text-gray-400">•</span>
        <time
          class="text-gray-400"
          datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toDateString()}
        </time>
        <span class="text-gray-400 hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            entry.data.tags.map((tag) => (
              <span class="text-sm text-gray-500">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6 max-w-3xl">
      <Content />
    </div>
    <div class="mx-auto mt-12 grid max-w-3xl gap-4 rounded-lg border border-gray-200 bg-gray-50 p-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <h2 class="text-xl font-semibold text-gray-900">Want to apply this to your business?</h2>
        <p class="mt-2 text-slate-600">
          Start with one workflow. First 2 months free, no commitment.
        </p>
      </div>
      <a
        href="/contact"
        class="rounded-sm bg-black px-5 py-3 text-center text-white transition hover:bg-gray-800"
        >Start free pilot</a
      >
    </div>
    <div class="text-center mt-8">
      <a href="/blog" class="text-slate-600 underline underline-offset-4">
        Back to Blog
      </a>
    </div>
  </Container>
</Layout>
