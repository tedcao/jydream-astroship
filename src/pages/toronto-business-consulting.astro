---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";

const problems = [
  "The website does not explain the service clearly enough.",
  "Leads arrive, but follow-up depends on memory.",
  "Customer questions are spread across too many channels.",
  "Service, accessory, or replacement reminders are manual.",
  "The owner needs visibility without running another complicated tool.",
];
---

<Layout
  title="Toronto Business Consulting"
  description="Toronto-based consulting for local service businesses that need better websites, customer service workflows, sales follow-up, accessory reminders, owner dashboards, and GEO-friendly content."
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Toronto business consulting for practical operations.</Fragment>
      <Fragment slot="desc">
        JYDream helps Toronto-area service businesses improve the workflow
        around website leads, customer questions, sales follow-up, reminders,
        and owner visibility.
      </Fragment>
    </Sectionhead>

    <section class="mx-auto mt-16 grid max-w-5xl gap-10 md:grid-cols-[1fr_0.9fr]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-[#F04E3E]">
          Local service business support
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-gray-900">
          More traffic does not help if the follow-up system is messy.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600">
          Many Toronto businesses do not need a giant software project. They
          need a clearer website, better customer intake, consistent follow-up,
          and reminders that help revenue happen on time.
        </p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <div class="text-sm font-semibold uppercase tracking-wide text-slate-500">
          Common problems
        </div>
        <ul class="mt-5 space-y-3 text-slate-700">
          {problems.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-5xl rounded-lg border border-gray-200 bg-gray-50 p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-gray-900">
            Start with one Toronto workflow.
          </h2>
          <p class="mt-3 leading-relaxed text-slate-600">
            First 2 months free. No commitment. Bring one messy lead, customer
            service, or reminder process.
          </p>
        </div>
        <Link href="/contact">Start free pilot</Link>
      </div>
    </section>
  </Container>
</Layout>
